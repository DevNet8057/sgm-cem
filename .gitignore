# .claude/ est versionné (agents, commandes, hooks, instructions) —
# seuls les fichiers propres à la machine restent locaux :
.claude/settings.local.json
**/.claude/launch.json
sgm-cem/.claude/
sgm-cem/packages/**/node_modules/
sgm-cem/packages/**/dist/
sgm-cem/node_modules/
sgm-cem/apps/**/node_modules/
sgm-cem/apps/**/.next/
sgm-cem/apps/**/dist/
sgm-cem/.env
sgm-cem/apps/**/.env
sgm-cem/apps/**/.env.local
sgm-cem/*.log
sgm-cem/api-direct-*.log
*.log
*.tsbuildinfo
# artefacts de debug de compilation (sorties tsc redirigées)
**/tsc_*.txt
# sauvegardes de base de données locales
sgm-cem/backup_*.sql
