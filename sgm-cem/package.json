{
  "name": "sgm-cem",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm build:shared && node scripts/dev.mjs",
    "build:shared": "pnpm --filter @sgm-cem/shared build",
    "build": "pnpm build:shared && pnpm --filter api build && pnpm --filter web build",
