# ─── BASE ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/sgm_cem"
REDIS_URL="redis://localhost:6379"
NODE_ENV="development"
PORT="3001"

# URLs — séparer par virgule pour autoriser plusieurs origines (ex: réseau local)
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# ─── SÉCURITÉ ─────────────────────────────────────────────────────────────────
# JWT — Générer avec : openssl rand -base64 64
JWT_SECRET="your-jwt-secret-min-256-bits"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"

# CSRF — Générer avec : openssl rand -base64 32
CSRF_SECRET="your-csrf-secret-change-in-prod"

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Se termine par .apps.googleusercontent.com — PAS le client secret (GOCSPX-...)
# Doit être identique à NEXT_PUBLIC_GOOGLE_CLIENT_ID dans apps/web/.env.local
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnopqrstuvwxyz123456.apps.googleusercontent.com

# ─── G1 : MTN MOBILE MONEY ────────────────────────────────────────────────────
# Portail : https://momodeveloper.mtn.com
# 1. Créer un compte développeur
# 2. S'abonner au produit "Collections"
# 3. Récupérer la clé primaire (Subscription Key) dans "Profile > Subscriptions"
# 4. Créer un API User via POST /v1_0/apiuser (sandbox) ou via le portail
# 5. Générer l'API Key via POST /v1_0/apiuser/{apiuser}/apikey
MTN_SUBSCRIPTION_KEY="your-mtn-subscription-key"
MTN_API_USER="your-mtn-api-user-uuid"
MTN_API_KEY="your-mtn-api-key"
MTN_ENVIRONMENT="sandbox"    # sandbox | production
MTN_MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"  # retirer en production (valeur par défaut utilisée)
# Optionnel : secret pour valider la signature des callbacks webhook MTN
MTN_WEBHOOK_SECRET="your-mtn-webhook-secret"

# ─── G2 : ORANGE MONEY ────────────────────────────────────────────────────────
# Option A — API directe Orange Cameroun (partenariat nécessaire, contacter Orange Business)
# Option B — Agrégateur tiers (Campay, Notchpay) : remplacer par les variables de l'agrégateur
ORANGE_CLIENT_ID="your-orange-client-id"
ORANGE_CLIENT_SECRET="your-orange-client-secret"
ORANGE_MERCHANT_KEY="your-orange-merchant-key"

# ─── G3 : EMAIL (SMTP) ────────────────────────────────────────────────────────
# Fournisseurs : Gmail, Outlook/Office365, SendGrid, Mailgun, etc.
# Gmail : activez "Mot de passe d'application" dans votre compte Google
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="votre.email@gmail.com"
SMTP_PASS="votre_mot_de_passe_application"
SMTP_FROM="CEM Melen <votre.email@gmail.com>"

# ─── G4 : WHATSAPP BUSINESS (360dialog) ───────────────────────────────────────
# 1. Créer un compte sur https://app.360dialog.com
# 2. Connecter un numéro WhatsApp Business (en production : numéro dédié)
# 3. Récupérer la clé API dans "Developers > API Keys"
# 4. Templates de message à valider par Meta avant utilisation en production
DIALOG360_API_KEY="your-360dialog-api-key"

# ─── G4 : SMS (Twilio) ────────────────────────────────────────────────────────
# Fallback WhatsApp → SMS
# 1. Créer un compte sur https://www.twilio.com
# 2. Récupérer Account SID et Auth Token dans la console
# 3. Acheter un numéro d'envoi (TWILIO_FROM)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM="+1xxxxxxxxxx"

# ─── G5 : STOCKAGE FICHIERS (S3-compatible) ───────────────────────────────────
# Sans ces variables, les fichiers sont sauvegardés localement dans uploads/
# Recommandé : Cloudflare R2 (gratuit jusqu'à 10 Go, S3-compatible)
#   → https://dash.cloudflare.com → R2 → Create bucket
#   → API tokens → Create token (Object Read & Write sur le bucket)
#   → S3_ENDPOINT format : https://<account-id>.r2.cloudflarestorage.com
#
# Ou AWS S3 :
#   → https://aws.amazon.com/s3/
#   → S3_ENDPOINT laisser vide (URL calculée automatiquement)
S3_BUCKET_NAME="sgm-cem-prod"
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"
S3_REGION="auto"          # "auto" pour R2, région AWS sinon (ex: eu-west-1)
S3_ENDPOINT=""            # Laisser vide pour AWS S3, renseigner pour R2 ou MinIO

# ─── H4 : CRON RELEVE MENSUEL ─────────────────────────────────────────────────
# Secret pour déclencher le cron manuellement via POST /api/admin/cron/monthly-statements
# Header attendu : X-Cron-Secret: <valeur>
CRON_SECRET="your-cron-secret"

# ─── H5 : YELII (MTN + Orange Money unifiés) ─────────────────────────────────
# Document API : https://api.yelii.xyz/docs
# URL de base : https://api.yelii.xyz/api/yelii-pro-pay/v1
# Webhook HMAC-SHA512 : HMAC(cle_collecte, timestamp + rawBody)
YELII_COLLECT_API_KEY="votre_cle_api_collecte_yelii"
YELII_API_KEY="votre_cle_api_yelii_legacy"
YELII_WEBHOOK_SECRET="votre_secret_webhook_yelii"
YELII_BASE_URL="https://api.yelii.xyz/api/yelii-pro-pay/v1"
